<?xml version="1.0" encoding="utf-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="400" height="400" viewBox="0 0 400 400">
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#06b6d4;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#3b82f6;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="400" height="400" fill="#1e293b"/>
  
  <!-- Profile circle background -->
  <circle cx="200" cy="200" r="190" fill="url(#grad1)" opacity="0.1"/>
  <circle cx="200" cy="200" r="180" fill="none" stroke="url(#grad1)" stroke-width="2" opacity="0.3"/>
  
  <!-- Head -->
  <circle cx="200" cy="120" r="50" fill="url(#grad1)"/>
  
  <!-- Body -->
  <ellipse cx="200" cy="240" rx="45" ry="60" fill="url(#grad1)"/>
  
  <!-- Left Arm -->
  <rect x="140" y="200" width="20" height="80" rx="10" fill="url(#grad1)" opacity="0.8"/>
  
  <!-- Right Arm -->
  <rect x="240" y="200" width="20" height="80" rx="10" fill="url(#grad1)" opacity="0.8"/>
  
  <!-- Decorative elements -->
  <circle cx="150" cy="150" r="8" fill="#06b6d4" opacity="0.5"/>
  <circle cx="250" cy="150" r="8" fill="#3b82f6" opacity="0.5"/>
  <circle cx="180" cy="280" r="6" fill="#06b6d4" opacity="0.5"/>
  <circle cx="220" cy="280" r="6" fill="#3b82f6" opacity="0.5"/>
  
  <!-- Text -->
  <text x="200" y="340" text-anchor="middle" fill="#06b6d4" font-size="16" font-weight="bold" font-family="Arial">Profile Photo</text>
  <text x="200" y="360" text-anchor="middle" fill="#94a3b8" font-size="12" font-family="Arial">Replace with actual image</text>
</svg>
