<?xml version="1.0" encoding="utf-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="400" height="400" viewBox="0 0 400 400">
  <defs>
    <linearGradient id="grad2" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#06b6d4;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#3b82f6;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="400" height="400" fill="#1e293b"/>
  
  <!-- Data visualization elements -->
  <!-- Bar chart -->
  <rect x="50" y="200" width="30" height="100" fill="url(#grad2)" opacity="0.8"/>
  <rect x="90" y="150" width="30" height="150" fill="url(#grad2)" opacity="0.8"/>
  <rect x="130" y="120" width="30" height="180" fill="url(#grad2)" opacity="0.8"/>
  <rect x="170" y="180" width="30" height="120" fill="url(#grad2)" opacity="0.8"/>
  <rect x="210" y="90" width="30" height="210" fill="url(#grad2)" opacity="0.8"/>
  
  <!-- Line chart -->
  <polyline points="50,300 100,250 150,280 200,200 250,240 300,150 350,180" 
            fill="none" stroke="#06b6d4" stroke-width="3" stroke-linecap="round"/>
  
  <!-- Data points -->
  <circle cx="50" cy="300" r="4" fill="#06b6d4"/>
  <circle cx="100" cy="250" r="4" fill="#06b6d4"/>
  <circle cx="150" cy="280" r="4" fill="#06b6d4"/>
  <circle cx="200" cy="200" r="4" fill="#06b6d4"/>
  <circle cx="250" cy="240" r="4" fill="#06b6d4"/>
  <circle cx="300" cy="150" r="4" fill="#06b6d4"/>
  <circle cx="350" cy="180" r="4" fill="#06b6d4"/>
  
  <!-- Decorative circles -->
  <circle cx="100" cy="80" r="30" fill="none" stroke="#3b82f6" stroke-width="2" opacity="0.5"/>
  <circle cx="100" cy="80" r="20" fill="none" stroke="#06b6d4" stroke-width="2" opacity="0.7"/>
  <circle cx="100" cy="80" r="10" fill="#06b6d4" opacity="0.8"/>
  
  <!-- Text -->
  <text x="200" y="350" text-anchor="middle" fill="#06b6d4" font-size="16" font-weight="bold" font-family="Arial">Data Analytics</text>
  <text x="200" y="370" text-anchor="middle" fill="#94a3b8" font-size="12" font-family="Arial">Replace with actual image</text>
</svg>
